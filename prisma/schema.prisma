// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
}

model Contadores {
  id                  Int      @id @default(autoincrement())
  Modelo              String?  @db.NVarChar(MAX)
  TipoImpresion       String?  @db.NVarChar(MAX)
  Ip                  String?  @db.NVarChar(MAX)
  Serie               String?  @db.NVarChar(MAX)
  ImpresionesBN       Int?
  ImpresionesColor    Int?
  TotalImpresiones    Int?
  Cliente             String?  @db.NVarChar(MAX)
  FechaCaptura        DateTime? @db.DateTime
  CostoTotal          Decimal?  @db.Decimal(18, 4)
  Responsable         String?  @db.NVarChar(MAX)
  Estatus             String?  @db.NVarChar(MAX)
  Adicional1          String?  @db.NVarChar(MAX)
  Adicional2          String?  @db.NVarChar(MAX)
  Adicional3          String?  @db.NVarChar(MAX)
  Adicional4          String?  @db.NVarChar(MAX)
  Adicional5          String?  @db.NVarChar(MAX)
  Adicional6          String?  @db.NVarChar(MAX)
  Adicional7          String?  @db.NVarChar(MAX)
  Adicional8          String?  @db.NVarChar(MAX)
  Adicional9          String?  @db.NVarChar(MAX)
  Adicional10         String?  @db.NVarChar(MAX)

  @@map("Contadores")
}