generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider          = "sqlserver"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  schemas = ["Evaluaciones","dbo"]
}

model Contadores {
  id               Int       @id(map: "PK__Contador__3213E83FE6DF4BDF") @default(autoincrement())
  Modelo           String?   @db.NVarChar(Max)
  TipoImpresion    String?   @db.NVarChar(Max)
  Ip               String?   @db.NVarChar(Max)
  Serie            String?   @db.NVarChar(Max)
  ImpresionesBN    Int?
  ImpresionesColor Int?
  TotalImpresiones Int?
  Cliente          String?   @db.NVarChar(Max)
  FechaCaptura     DateTime? @db.DateTime
  CostoTotal       Decimal?  @db.Decimal(18, 4)
  Responsable      String?   @db.NVarChar(Max)
  Estatus          String?   @db.NVarChar(Max)
  TipoImpresora    String?   @db.NVarChar(Max)
  Adicional2       String?   @db.NVarChar(Max)
  Adicional3       String?   @db.NVarChar(Max)
  Adicional4       String?   @db.NVarChar(Max)
  Adicional5       String?   @db.NVarChar(Max)
  Adicional6       String?   @db.NVarChar(Max)
  Adicional7       String?   @db.NVarChar(Max)
  Adicional8       String?   @db.NVarChar(Max)
  Adicional9       String?   @db.NVarChar(Max)
  Adicional10      String?   @db.NVarChar(Max)

  @@map("Contadores")
  @@schema("dbo")
}

model ContadoresInfoClientes {
  id                  Int       @id(map: "PK__Contador__3213E83F33652050") @default(autoincrement())
  Cliente             String?   @db.NVarChar(Max)
  Modelo              String?   @db.NVarChar(Max)
  Serie               String?   @db.NVarChar(Max)
  IP                  String?   @db.NVarChar(Max)
  ImpresionesActuales Int?
  BN                  Int?
  Color               Int?
  Tecnico             String?   @db.NVarChar(Max)
  FechaLimiteReporte  DateTime? @default(now(), map: "DF__Contadore__Fecha__74AE54BC") @db.DateTime
  PrecioBN            Decimal?  @db.Decimal(10, 2)
  PrecioColor         Decimal?  @db.Decimal(10, 2)
  RentaFija           Decimal?  @db.Decimal(10, 2)
  CostoExtra          Decimal?  @db.Decimal(10, 2)
  Ubicacion           String?   @db.VarChar(50)

  @@map("ContadoresInfoClientes")
  @@schema("dbo")
}

model Predicciones_Archivos {
  Id               String   @id(map: "PK_Predicciones_Archivos") @default(dbgenerated("newid()"), map: "DF__Predicciones__Id__31B762FC") @db.UniqueIdentifier
  Tipo             String   @db.NVarChar(30)
  ModeloSlug       String?  @db.NVarChar(64)
  MesObjetivo      String?  @db.Char(7)
  UploadedByUserId String?  @db.NVarChar(128)
  FileName         String   @db.NVarChar(260)
  ContentType      String?  @db.NVarChar(100)
  FileSizeBytes    BigInt?
  FileContent      Bytes
  HashSha256       String?  @db.NVarChar(64)
  MetaJson         String?  @db.NVarChar(Max)
  CreatedAt        DateTime @default(dbgenerated("sysdatetime()"), map: "DF__Prediccio__Creat__32AB8735")

  @@index([ModeloSlug, MesObjetivo, Tipo, CreatedAt(sort: Desc)], map: "IX_Predicciones_Archivos_ModeloMesTipo")
  @@schema("dbo")
}

model Predicciones_Modelos {
  Id            String   @id(map: "PK_Predicciones_Modelos") @default(dbgenerated("newid()"), map: "DF__Predicciones__Id__1CBC4616") @db.UniqueIdentifier
  Slug          String   @unique(map: "UQ_Predicciones_Modelos_Slug") @db.NVarChar(64)
  Nombre        String   @db.NVarChar(128)
  Estado        String   @db.NVarChar(20)
  VersionActual String?  @db.NVarChar(40)
  Descripcion   String?  @db.NVarChar(500)
  ConfigJson    String?  @db.NVarChar(Max)
  CreatedAt     DateTime @default(dbgenerated("sysdatetime()"), map: "DF__Prediccio__Creat__1DB06A4F")
  UpdatedAt     DateTime @default(dbgenerated("sysdatetime()"), map: "DF__Prediccio__Updat__1EA48E88")

  @@index([Slug], map: "IX_Predicciones_Modelos_Slug")
  @@schema("dbo")
}

model Predicciones_Requests {
  Id          String    @id(map: "PK_Predicciones_Requests") @db.UniqueIdentifier
  UserEmail   String    @db.NVarChar(256)
  UserName    String    @db.NVarChar(256)
  ModelSlug   String    @db.NVarChar(100)
  ModelName   String    @db.NVarChar(200)
  MonthTarget String?   @db.Char(7)
  Status      String    @db.VarChar(20)
  CreatedAt   DateTime
  CompletedAt DateTime?
  MetaJson    String?   @db.NVarChar(Max)

  @@index([ModelSlug, MonthTarget], map: "IX_PredRequests_ModelMonth")
  @@index([Status, CreatedAt(sort: Desc)], map: "IX_PredRequests_StatusCreatedAt")
  @@schema("dbo")
}

model ProductoPendienteValidation {
  id                          Int      @id @default(autoincrement())
  sku                         String   @db.NVarChar(100)
  descripcion_comercial       String?  @db.NVarChar(Max)
  clave_producto_servicio_sat String?  @db.NVarChar(50)
  clave_unidad_sat            String?  @db.NVarChar(50)
  marca                       String?  @db.NVarChar(100)
  medidas_cm                  String?  @db.NVarChar(100)
  peso_kg                     Float?
  user_email                  String   @db.NVarChar(256)
  status                      String   @default("Pending") @db.NVarChar(50)
  createdAt                   DateTime @default(now())

  @@index([user_email, status], map: "IX_ProductoPendiente_UserStatus")
  @@schema("dbo")
}

model catalogo_Aplicaciones {
  id           Int                      @id(map: "PK__aplicaci__3213E83F617A4352") @default(autoincrement())
  nombre       String                   @db.NVarChar(120)
  descripcion  String?                  @db.NVarChar(Max)
  tipo         String                   @default("agente", map: "DF__aplicacion__tipo__531856C7") @db.NVarChar(50)
  area         String?                  @db.NVarChar(80)
  icono        String?                  @default("??", map: "DF__aplicacio__icono__540C7B00") @db.NVarChar(10)
  estado       String                   @default("piloto", map: "DF__aplicacio__estad__55009F39") @db.NVarChar(20)
  fecha_inicio DateTime                 @db.Date
  creado_en    DateTime                 @default(now(), map: "DF__aplicacio__cread__55F4C372")
  costos       catalogo_Costos[]
  metricas     catalogo_Metricas[]

  @@map("aplicaciones")
  @@schema("dbo")
}

model catalogo_Configuraciones {
  id            Int                  @id(map: "PK__configur__3213E83F755E0D93") @default(autoincrement())
  costo_hora    Decimal              @db.Decimal(8, 2)
  vigente_desde DateTime             @default(now(), map: "DF__configura__vigen__4F47C5E3") @db.Date
  creado_en     DateTime             @default(now(), map: "DF__configura__cread__503BEA1C")
  metricas      catalogo_Metricas[]

  @@map("configuraciones")
  @@schema("dbo")
}

model catalogo_Costos {
  id                  Int                    @id(map: "PK__costos__3213E83FAC430E27") @default(autoincrement())
  aplicacion_id       Int
  concepto            String                 @db.NVarChar(120)
  monto               Decimal                @db.Decimal(10, 2)
  fecha               DateTime               @default(now(), map: "DF__costos__fecha__607251E5") @db.Date
  creado_en           DateTime               @default(now(), map: "DF__costos__creado_e__6166761E")
  aplicaciones        catalogo_Aplicaciones  @relation(fields: [aplicacion_id], references: [id], onUpdate: NoAction, map: "FK__costos__aplicaci__5F7E2DAC")

  @@map("costos")
  @@schema("dbo")
}

model catalogo_Metricas {
  id                  Int                    @id(map: "PK__metricas__3213E83F244C2BD6") @default(autoincrement())
  aplicacion_id       Int
  configuracion_id    Int
  periodo             DateTime               @db.Date
  tiempo_antes_min    Decimal                @db.Decimal(8, 2)
  tiempo_ahora_min    Decimal                @db.Decimal(8, 2)
  ejecuciones_por_dia Int                    @default(1, map: "DF__metricas__ejecuc__5BAD9CC8")
  usuarios_activos    Int                    @default(0, map: "DF__metricas__usuari__5CA1C101")
  hito                String?                @db.NVarChar(Max)
  aplicaciones        catalogo_Aplicaciones  @relation(fields: [aplicacion_id], references: [id], onUpdate: NoAction, map: "FK__metricas__aplica__59C55456")
  configuraciones     catalogo_Configuraciones @relation(fields: [configuracion_id], references: [id], onUpdate: NoAction, map: "FK__metricas__config__5AB9788F")

  @@unique([aplicacion_id, periodo], map: "UQ__metricas__93D9ED41540EBEB4")
  @@map("metricas")
  @@schema("dbo")
}


// Catalogo central de modelos de IA usados por los agentes, con proveedor y costos separados de input/output.
model Models {
  id                        Int       @id @default(autoincrement())
  name                      String    @db.NVarChar(100)
  version                   String?   @db.NVarChar(100)
  suscripcionID             String?   @db.NVarChar(100)
  status                    String?   @db.NVarChar(100)
  proveedor                 String    @db.NVarChar(100)
  inputTokenCostPerMillion  Decimal?  @db.Decimal(18, 6)
  outputTokenCostPerMillion Decimal?  @db.Decimal(18, 6)
  createdAt                 DateTime  @default(now()) @db.DateTime
  updatedAt                 DateTime  @updatedAt @db.DateTime
  agentes                   Agentes[]
  usos                      UsesModels[]
  acciones                  AgentActions[]

  @@index([name, version, proveedor], map: "IX_AI_Models_NameVersionProvider")
  @@map("AI_Models")
  @@schema("dbo")
}

// Catalogo de agentes de IA de la plataforma para reutilizar trazabilidad en modulos futuros.
model Agentes {
  id            String         @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  nombre_logico String         @db.NVarChar(120)
  nombre_publico String?       @db.NVarChar(120)
  idModelo      Int?
  plataforma    String?        @db.NVarChar(100)
  estatus       String?        @db.NVarChar(40)
  createdAt     DateTime       @default(now()) @db.DateTime
  updatedAt     DateTime       @updatedAt @db.DateTime
  modelo        Models?        @relation(fields: [idModelo], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usos          UsesModels[]
  acciones      AgentActions[]

  messages    Message[]
  @@index([nombre_logico], map: "IX_AI_Agentes_NombreLogico")
  @@index([idModelo], map: "IX_AI_Agentes_IdModelo")
  @@map("AI_Agentes")
  @@schema("dbo")
}

// Registro agregado de consumo de modelos por corrida (tokens, tiempos y costo estimado) para analitica transversal.
model UsesModels {
  id                             BigInt    @id @default(autoincrement())
  idModel                        Int
  colaboradorID                  String?   @db.NVarChar(200)
  project                        String?   @db.NVarChar(100)
  module                         String?   @db.NVarChar(100)
  timeEjecucionSec               Float?
  averageTimeHumaneJecutationSec Float?
  tokensInput                    Int?
  tokensOutput                   Int?
  tokensTotal                    Int?
  costAverage                    Decimal?  @db.Decimal(18, 6)
  agentId                        String?   @db.UniqueIdentifier
  sessionId                      String?   @db.NVarChar(120)
  runId                          String?   @db.NVarChar(120)
  createdAt                      DateTime  @default(now()) @db.DateTime
  model                          Models    @relation(fields: [idModel], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agent                          Agentes?  @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([idModel, createdAt], map: "IX_AI_UsesModels_ModelCreatedAt")
  @@index([project, module], map: "IX_AI_UsesModels_ProjectModule")
  @@index([sessionId], map: "IX_AI_UsesModels_SessionId")
  @@index([runId], map: "IX_AI_UsesModels_RunId")
  @@map("AI_UsesModels")
  @@schema("dbo")
}

// Bitacora detallada por accion de cada corrida de agente (pasos, comandos, errores, estado final y consumo de tokens por accion LLM).
model AgentActions {
  id           BigInt    @id @default(autoincrement())
  runId        String    @db.NVarChar(120)
  sessionId    String?   @db.NVarChar(120)
  agentId      String?   @db.UniqueIdentifier
  modelId      Int?
  project      String?   @db.NVarChar(100)
  module       String?   @db.NVarChar(100)
  actionType   String    @db.NVarChar(60)
  stepId       String?   @db.NVarChar(120)
  description  String?   @db.NVarChar(Max)
  status       String?   @db.NVarChar(40)
  tokensInput  Int?
  tokensOutput Int?
  tokensTotal  Int?
  costAverage  Decimal?  @db.Decimal(18, 6)
  durationMs   Int?
  payloadJson  String?   @db.NVarChar(Max)
  errorMessage String?   @db.NVarChar(Max)
  createdAt    DateTime  @default(now()) @db.DateTime
  agent        Agentes?  @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  model        Models?   @relation(fields: [modelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([runId, createdAt], map: "IX_AI_AgentActions_RunCreatedAt")
  @@index([sessionId], map: "IX_AI_AgentActions_SessionId")
  @@index([project, module], map: "IX_AI_AgentActions_ProjectModule")
  @@index([actionType], map: "IX_AI_AgentActions_ActionType")
  @@map("AI_AgentActions")
  @@schema("dbo")
}


// paqueterias
model Paqueterias {
  id          Int            @id(map: "PK__paqueter__3213E83FBA1B9C8B") @default(autoincrement())
  nombre      String         @db.NVarChar(100)
  descripcion String?        @db.NVarChar(Max)
  createdAt   DateTime       @default(now(), map: "DF__paqueter__creado__6FE99F9F")
  updatedAt   DateTime       @default(now(), map: "DF__paqueter__actuali__70A8B9B2")
  deleted     Boolean        @default(false, map: "DF__paqueter__delet__71D1E811")
  deletedAt   DateTime?      @db.DateTime

  // Relaciones
  cotizaciones Cotizaciones[]
  envios       Envios[]

  @@map("paqueterias")
  @@schema("dbo")
}

model Cotizaciones {
  id             Int          @id(map: "PK__cotizacio__3213E83F1B9CDBF7") @default(autoincrement())
  usuario        String       @db.NVarChar(100)
  idPaqueteria   Int          @db.Int
  dimensiones     String       @db.NVarChar(100) // ej. "30x20x10 cm"
  unidadNegocio     String?      @db.NVarChar(100) // ej. "GSA", "Gestion de talento", etc.
  peso           Decimal      @db.Decimal(10, 2)
  ciudadOrigen   String       @db.NVarChar(100)
  cpOrigen       String       @db.NVarChar(20)
  ciudadDestino  String       @db.NVarChar(100)
  cpDestino      String       @db.NVarChar(20)
  costoEstimado  Decimal?     @db.Decimal(10, 2) // <-- NUEVO: Para comparar contra el costo real
  status         String       @default("PENDIENTE") @db.NVarChar(20)
  reviewedBy     String?      @db.NVarChar(100)
  reviewedAt     DateTime?
  motivoRechazo  String?      @db.NVarChar(300)
  serviceType     String?      @db.NVarChar(100) // ej. "express", "standard"
  fecha          DateTime     @default(now(), map: "DF__cotizacio__fecha__72C60C4A")
  createdAt      DateTime     @default(now(), map: "DF__cotizacio__creado__73BA3080")
  updatedAt      DateTime     @default(now(), map: "DF__cotizacio__actuali__74ABBAE5")
  deleted        Boolean      @default(false, map: "DF__cotizacio__delet__75A278F6")
  deletedAt      DateTime?    @db.DateTime

  // Relaciones
  paqueteria     Paqueterias  @relation(fields: [idPaqueteria], references: [id])
  envios         Envios[]

  @@map("cotizaciones")
  @@schema("dbo")
}

model Envios {
  id             Int          @id(map: "PK__envios__3213E83F2B9CDBF7") @default(autoincrement())
  idCotizacion   Int?         @db.Int // Opcional, por si se crea un envío sin cotizar primero
  idPaqueteria   Int          @db.Int
  unidadNegocio     String?      @db.NVarChar(100) // ej. "GSA", "Gestion de talento", etc.
  usuario        String       @db.NVarChar(100)
  estado         String       @default("CREADO") @db.NVarChar(50) // <-- NUEVO: CREADO, TRANSITO, ENTREGADO
  dimensiones     String       @db.NVarChar(100) // ej. "30x20x10 cm"
  peso           Decimal      @db.Decimal(10, 2)
  ciudadOrigen   String       @db.NVarChar(100)
  cpOrigen       String       @db.NVarChar(20)
  ciudadDestino  String       @db.NVarChar(100)
  cpDestino      String       @db.NVarChar(20)
  serviceType     String?      @db.NVarChar(100) // ej. "express", "standard"
  costoEnvio     Decimal      @db.Decimal(10, 2)
  impuestos      Decimal      @db.Decimal(10, 2)
  fechaEnvio     DateTime     @default(now(), map: "DF__envios__fecha__76A278F6")
  createdAt      DateTime     @default(now(), map: "DF__envios__creado__77A278F6")
  updatedAt      DateTime     @default(now(), map: "DF__envios__actuali__78A278F6")
  deleted        Boolean      @default(false, map: "DF__envios__delet__79A278F6")
  deletedAt      DateTime?    @db.DateTime
  comentarios      String?      @db.NVarChar(Max) // Para que el usuario o el agente puedan agregar notas al envío

// Relaciones (AQUÍ ESTÁ LA MAGIA)
  cotizacion     Cotizaciones? @relation(fields: [idCotizacion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paqueteria     Paqueterias   @relation(fields: [idPaqueteria], references: [id], onDelete: NoAction, onUpdate: NoAction)
  guias          GuiasEnvio[]

  @@map("envios")
  @@schema("dbo")
}

model GuiasEnvio {
  id             Int          @id(map: "PK__guias_env__3213E83F8B9CDBF7") @default(autoincrement())
  idEnvio        Int          @db.Int // <-- Modificado para ligarlo a la cabecera del envío
  numeroGuia     String       @unique @db.NVarChar(100) // <-- UNIQUE para buscar rápido con la API
  estadoGuia     String?      @db.NVarChar(100) // <-- Por si una caja llega y otra no
  fechaEnvio     DateTime     @default(now(), map: "DF__guias_env__fecha__76A278F6")
  createdAt      DateTime     @default(now(), map: "DF__guias_env__creado__77A278F6")
  updatedAt      DateTime     @default(now(), map: "DF__guias_env__actuali__78A278F6")
  deleted        Boolean      @default(false, map: "DF__guias_env__delet__79A278F6")
  deletedAt      DateTime?    @db.DateTime

  // Relaciones
  envio          Envios                  @relation(fields: [idEnvio], references: [id])
  documentos     ExtraccionDocumentos[]
  cargos         CargosPaqueteria[]

  @@map("guias_envio")
  @@schema("dbo")
}

model ExtraccionDocumentos {
  id               Int          @id(map: "PK__extracc__3213E83F9B9CDBF7") @default(autoincrement())
  idGuiaEnvio      Int          @db.Int
  tipoDocumento    String       @db.NVarChar(100) // ej. "waybill", "commercial-invoice"
  fechaExtraccion  DateTime     @default(now(), map: "DF__extracc__fecha__7A278F6")
  createdAt        DateTime     @default(now(), map: "DF__extracc__creado__7B278F6")
  updatedAt        DateTime     @default(now(), map: "DF__extracc__actuali__7C278F6")
  deleted          Boolean      @default(false, map: "DF__extracc__delet__7D278F6")
  deletedAt        DateTime?    @db.DateTime

  // Relaciones
  guia             GuiasEnvio   @relation(fields: [idGuiaEnvio], references: [id])

  @@map("extraccion_documentos")
  @@schema("dbo")
}

model CargosPaqueteria {
  id             Int          @id(map: "PK__cargos_p__3213E83FBB9CDBF7") @default(autoincrement())
  idGuiaEnvio    Int          @db.Int
  descripcion    String       @db.NVarChar(200)
  url_factura    String?      @db.NVarChar(200)
  monto          Decimal      @db.Decimal(10, 2)
  concepto       String       @db.NVarChar(100)
  ejecutivo      String       @db.NVarChar(100)
  fechaCargo     DateTime     @default(now(), map: "DF__cargos_p__fecha__7E278F6")
  createdAt      DateTime     @default(now(), map: "DF__cargos_p__creado__7F278F6")
  updatedAt      DateTime     @default(now(), map: "DF__cargos_p__actuali__80278F6")
  deleted        Boolean      @default(false, map: "DF__cargos_p__delet__81278F6")
  deletedAt      DateTime?    @db.DateTime

  // Relaciones
  guia           GuiasEnvio   @relation(fields: [idGuiaEnvio], references: [id])

  @@map("cargos_paqueteria")
  @@schema("dbo")
}

model ReportesGenerados {
  id               Int          @id(map: "PK__reportes__3213E83FCD9CDBF7") @default(autoincrement())
  tipoReporte      String       @db.NVarChar(100)
  usuario          String       @db.NVarChar(100)
  plataforma       String       @db.NVarChar(100)
  fechaGeneracion  DateTime     @default(now(), map: "DF__reportes__fecha__82278F6")
  createdAt        DateTime     @default(now(), map: "DF__reportes__creado__83278F6")
  updatedAt        DateTime     @default(now(), map: "DF__reportes__actuali__84278F6")
  deleted          Boolean      @default(false, map: "DF__reportes__delet__85278F6")
  deletedAt        DateTime?    @db.DateTime

  @@map("reportes_generados")
  @@schema("dbo")
}

model Thread {
  id              Int          @id(map: "PK__thread__3213E83FDD9CDBF7") @default(autoincrement())
  titulo          String       @db.NVarChar(200)
  usuario         String       @db.NVarChar(100)
  plataforma      String       @db.NVarChar(100)
  fechaCreacion   DateTime     @default(now(), map: "DF__thread__fecha__86278F6")
  createdAt       DateTime     @default(now(), map: "DF__thread__creado__87278F6")
  updatedAt       DateTime     @default(now(), map: "DF__thread__actuali__88278F6")
  deleted         Boolean      @default(false, map: "DF__thread__delet__89278F6")
  deletedAt       DateTime?    @db.DateTime

  // Relaciones Inversas
  messages        Message[]

  @@map("threads")
  @@schema("dbo")
}

model Message {
  id              Int          @id(map: "PK__message__3213E83FEE9CDBF7") @default(autoincrement())
  threadId        Int          @db.Int
  agente_id       String?      @db.UniqueIdentifier
  usuario         String?      @db.NVarChar(100)
  role            String       @default("user") @db.NVarChar(50) // <-- NUEVO: "user", "assistant", "system"
  contenido       String       @db.NVarChar(Max)
  fechaCreacion   DateTime     @default(now(), map: "DF__message__fecha__8A278F6")
  createdAt       DateTime     @default(now(), map: "DF__message__creado__8B278F6")
  updatedAt       DateTime     @default(now(), map: "DF__message__actuali__8C278F6")
  deleted         Boolean      @default(false, map: "DF__message__delet__8D278F6")
  deletedAt       DateTime?    @db.DateTime

  // Relaciones
  thread          Thread       @relation(fields: [threadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agente          Agentes?     @relation(fields: [agente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Relación Inversa
  feedbacks       Feedback[]

  @@map("messages")
  @@schema("dbo")
}

model Feedback {
  id              Int          @id(map: "PK__feedback__3213E83FF9CDBF7") @default(autoincrement())
  messageId       Int          @db.Int
  usuario         String       @db.NVarChar(100)
  calificacion    Int          @db.Int // Ej. 1-5 o 0-1 (Thumbs up/down)
  comentario      String?      @db.NVarChar(Max)
  fechaCreacion   DateTime     @default(now(), map: "DF__feedback__fecha__8E278F6")
  createdAt       DateTime     @default(now(), map: "DF__feedback__creado__8F278F6")
  updatedAt       DateTime     @default(now(), map: "DF__feedback__actuali__90278F6")
  deleted         Boolean      @default(false, map: "DF__feedback__delet__91278F6")
  deletedAt       DateTime?    @db.DateTime

  // Relaciones
  message         Message      @relation(fields: [messageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("feedback")
  @@schema("dbo")
}

model EvaluacionesExamen {
  id     Int    @id @default(autoincrement())
  nombre String

  @@map("examen") 
  @@schema("Evaluaciones") 
}

model EvaluacionesIncisos {
  idPregunta Int
  letra      String
  texto      String
  puntos     Int?
  idExamen   Int?

  // Llave primaria compuesta
  @@id([idPregunta, letra])
  
  // Mapeo exacto del nombre de la tabla en la base de datos
  @@map("Incisos")
  
  // Asignación al esquema específico
  @@schema("Evaluaciones")
}

model EvaluacionesPreguntas {
  id            Int     @id @default(autoincrement())
  pregunta      String
  respuesta     String?
  puntosMaximos Int?
  idExamen      Int
  nivel         String?
  tipo          String?

  @@map("preguntas")
  @@schema("Evaluaciones")
}

model EvaluacionesRanking {
