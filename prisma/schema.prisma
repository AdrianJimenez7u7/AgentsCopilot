generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider          = "sqlserver"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Contadores {
  id               Int       @id(map: "PK__Contador__3213E83FE6DF4BDF") @default(autoincrement())
  Modelo           String?   @db.NVarChar(Max)
  TipoImpresion    String?   @db.NVarChar(Max)
  Ip               String?   @db.NVarChar(Max)
  Serie            String?   @db.NVarChar(Max)
  ImpresionesBN    Int?
  ImpresionesColor Int?
  TotalImpresiones Int?
  Cliente          String?   @db.NVarChar(Max)
  FechaCaptura     DateTime? @db.DateTime
  CostoTotal       Decimal?  @db.Decimal(18, 4)
  Responsable      String?   @db.NVarChar(Max)
  Estatus          String?   @db.NVarChar(Max)
  TipoImpresora    String?   @db.NVarChar(Max)
  Adicional2       String?   @db.NVarChar(Max)
  Adicional3       String?   @db.NVarChar(Max)
  Adicional4       String?   @db.NVarChar(Max)
  Adicional5       String?   @db.NVarChar(Max)
  Adicional6       String?   @db.NVarChar(Max)
  Adicional7       String?   @db.NVarChar(Max)
  Adicional8       String?   @db.NVarChar(Max)
  Adicional9       String?   @db.NVarChar(Max)
  Adicional10      String?   @db.NVarChar(Max)

  @@map("Contadores")
}

model ContadoresInfoClientes {
  id                  Int       @id(map: "PK__Contador__3213E83F33652050") @default(autoincrement())
  Cliente             String?   @db.NVarChar(Max)
  Modelo              String?   @db.NVarChar(Max)
  Serie               String?   @db.NVarChar(Max)
  IP                  String?   @db.NVarChar(Max)
  ImpresionesActuales Int?
  BN                  Int?
  Color               Int?
  Tecnico             String?   @db.NVarChar(Max)
  FechaLimiteReporte  DateTime? @default(now(), map: "DF__Contadore__Fecha__74AE54BC") @db.DateTime
  PrecioBN            Decimal?  @db.Decimal(10, 2)
  PrecioColor         Decimal?  @db.Decimal(10, 2)
  RentaFija           Decimal?  @db.Decimal(10, 2)
  CostoExtra          Decimal?  @db.Decimal(10, 2)
  Ubicacion           String?   @db.VarChar(50)

  @@map("ContadoresInfoClientes")
}

model Predicciones_Archivos {
  Id               String   @id(map: "PK_Predicciones_Archivos") @default(dbgenerated("newid()"), map: "DF__Predicciones__Id__31B762FC") @db.UniqueIdentifier
  Tipo             String   @db.NVarChar(30)
  ModeloSlug       String?  @db.NVarChar(64)
  MesObjetivo      String?  @db.Char(7)
  UploadedByUserId String?  @db.NVarChar(128)
  FileName         String   @db.NVarChar(260)
  ContentType      String?  @db.NVarChar(100)
  FileSizeBytes    BigInt?
  FileContent      Bytes
  HashSha256       String?  @db.NVarChar(64)
  MetaJson         String?  @db.NVarChar(Max)
  CreatedAt        DateTime @default(dbgenerated("sysdatetime()"), map: "DF__Prediccio__Creat__32AB8735")

  @@index([ModeloSlug, MesObjetivo, Tipo, CreatedAt(sort: Desc)], map: "IX_Predicciones_Archivos_ModeloMesTipo")
}

model Predicciones_Modelos {
  Id            String   @id(map: "PK_Predicciones_Modelos") @default(dbgenerated("newid()"), map: "DF__Predicciones__Id__1CBC4616") @db.UniqueIdentifier
  Slug          String   @unique(map: "UQ_Predicciones_Modelos_Slug") @db.NVarChar(64)
  Nombre        String   @db.NVarChar(128)
  Estado        String   @db.NVarChar(20)
  VersionActual String?  @db.NVarChar(40)
  Descripcion   String?  @db.NVarChar(500)
  ConfigJson    String?  @db.NVarChar(Max)
  CreatedAt     DateTime @default(dbgenerated("sysdatetime()"), map: "DF__Prediccio__Creat__1DB06A4F")
  UpdatedAt     DateTime @default(dbgenerated("sysdatetime()"), map: "DF__Prediccio__Updat__1EA48E88")

  @@index([Slug], map: "IX_Predicciones_Modelos_Slug")
}

model Predicciones_Requests {
  Id          String    @id(map: "PK_Predicciones_Requests") @db.UniqueIdentifier
  UserEmail   String    @db.NVarChar(256)
  UserName    String    @db.NVarChar(256)
  ModelSlug   String    @db.NVarChar(100)
  ModelName   String    @db.NVarChar(200)
  MonthTarget String?   @db.Char(7)
  Status      String    @db.VarChar(20)
  CreatedAt   DateTime
  CompletedAt DateTime?
  MetaJson    String?   @db.NVarChar(Max)

  @@index([ModelSlug, MonthTarget], map: "IX_PredRequests_ModelMonth")
  @@index([Status, CreatedAt(sort: Desc)], map: "IX_PredRequests_StatusCreatedAt")
}

model ProductoPendienteValidation {
  id                          Int      @id @default(autoincrement())
  sku                         String   @db.NVarChar(100)
  descripcion_comercial       String?  @db.NVarChar(Max)
  clave_producto_servicio_sat String?  @db.NVarChar(50)
  clave_unidad_sat            String?  @db.NVarChar(50)
  marca                       String?  @db.NVarChar(100)
  medidas_cm                  String?  @db.NVarChar(100)
  peso_kg                     Float?
  user_email                  String   @db.NVarChar(256)
  status                      String   @default("Pending") @db.NVarChar(50)
  createdAt                   DateTime @default(now())

  @@index([user_email, status], map: "IX_ProductoPendiente_UserStatus")
}

model Catalogo_Configuraciones {
  id            Int                 @id(map: "PK__configur__3213E83F755E0D93") @default(autoincrement())
  costo_hora    Decimal             @db.Decimal(8, 2)
  vigente_desde DateTime            @default(now(), map: "DF__configura__vigen__4F47C5E3") @db.Date
  creado_en     DateTime            @default(now(), map: "DF__configura__cread__503BEA1C")
  metricas      Catalogo_Metricas[]

  @@map("configuraciones")
}

model Catalogo_Aplicaciones {
  id           Int                 @id(map: "PK__aplicaci__3213E83F617A4352") @default(autoincrement())
  nombre       String              @db.NVarChar(120)
  descripcion  String?             @db.NVarChar(Max)
  tipo         String              @default("agente", map: "DF__aplicacion__tipo__531856C7") @db.NVarChar(50)
  area         String?             @db.NVarChar(80)
  icono        String?             @default("??", map: "DF__aplicacio__icono__540C7B00") @db.NVarChar(10)
  estado       String              @default("piloto", map: "DF__aplicacio__estad__55009F39") @db.NVarChar(20)
  fecha_inicio DateTime            @db.Date
  creado_en    DateTime            @default(now(), map: "DF__aplicacio__cread__55F4C372")
  costos       Catalogo_Costos[]
  metricas     Catalogo_Metricas[]

  @@map("aplicaciones")
}

model Catalogo_Metricas {
  id                  Int                      @id(map: "PK__metricas__3213E83F244C2BD6") @default(autoincrement())
  aplicacion_id       Int
  configuracion_id    Int
  periodo             DateTime                 @db.Date
  tiempo_antes_min    Decimal                  @db.Decimal(8, 2)
  tiempo_ahora_min    Decimal                  @db.Decimal(8, 2)
  ejecuciones_por_dia Int                      @default(1, map: "DF__metricas__ejecuc__5BAD9CC8")
  usuarios_activos    Int                      @default(0, map: "DF__metricas__usuari__5CA1C101")
  hito                String?                  @db.NVarChar(Max)
  aplicacion          Catalogo_Aplicaciones    @relation(fields: [aplicacion_id], references: [id], onUpdate: NoAction, map: "FK__metricas__aplica__59C55456")
  configuracion       Catalogo_Configuraciones @relation(fields: [configuracion_id], references: [id], onUpdate: NoAction, map: "FK__metricas__config__5AB9788F")

  @@unique([aplicacion_id, periodo], map: "UQ__metricas__93D9ED41540EBEB4")
  @@map("metricas")
}

model Catalogo_Costos {
  id            Int                   @id(map: "PK__costos__3213E83FAC430E27") @default(autoincrement())
  aplicacion_id Int
  concepto      String                @db.NVarChar(120)
  monto         Decimal               @db.Decimal(10, 2)
  fecha         DateTime              @default(now(), map: "DF__costos__fecha__607251E5") @db.Date
  creado_en     DateTime              @default(now(), map: "DF__costos__creado_e__6166761E")
  aplicacion    Catalogo_Aplicaciones @relation(fields: [aplicacion_id], references: [id], onUpdate: NoAction, map: "FK__costos__aplicaci__5F7E2DAC")

  @@map("costos")
}
