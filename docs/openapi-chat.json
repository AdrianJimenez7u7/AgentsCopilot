{
  "openapi": "3.0.3",
  "info": {
    "title": "Operaciones Chat API",
    "version": "1.0.0",
    "description": "API para chat con el agente de operaciones."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local"
    }
  ],
  "paths": {
    "/agent/sendMessage": {
      "post": {
        "summary": "Enviar mensaje al agente",
        "operationId": "sendAgentMessage",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensaje procesado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Solicitud invalida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Error interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/agent/threads": {
      "get": {
        "summary": "Listar hilos del usuario",
        "operationId": "listAgentThreads",
        "parameters": [
          {
            "name": "userEmail",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de hilos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Solicitud invalida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Error interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/agent/threads/{threadId}/messages": {
      "get": {
        "summary": "Obtener mensajes del hilo",
        "operationId": "getThreadMessages",
        "parameters": [
          {
            "name": "threadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "userEmail",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Mensajes del hilo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadMessagesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Solicitud invalida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Thread no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Error interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "required": ["message", "user"],
        "properties": {
          "history": {
            "type": "array",
            "description": "Historial opcional de mensajes previos.",
            "items": {
              "$ref": "#/components/schemas/HistoryItem"
            }
          },
          "message": {
            "type": "string",
            "description": "Mensaje actual del usuario."
          },
          "threadId": {
            "type": "integer",
            "format": "int32",
            "description": "Id del hilo. Si se omite, se crea uno nuevo."
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "SendMessageResponse": {
        "type": "object",
        "required": ["message", "threadId", "data"],
        "properties": {
          "message": {
            "type": "string"
          },
          "threadId": {
            "type": "integer",
            "format": "int32"
          },
          "data": {
            "$ref": "#/components/schemas/AgentDecision"
          }
        }
      },
      "ThreadsResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Thread"
            }
          }
        }
      },
      "ThreadMessagesResponse": {
        "type": "object",
        "required": ["thread", "messages"],
        "properties": {
          "thread": {
            "$ref": "#/components/schemas/Thread"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            }
          }
        }
      },
      "Thread": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "titulo": {
            "type": "string"
          },
          "usuario": {
            "type": "string"
          },
          "plataforma": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "threadId": {
            "type": "integer",
            "format": "int32"
          },
          "usuario": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "contenido": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AgentDecision": {
        "type": "object",
        "required": ["intencion", "datos_completos"],
        "properties": {
          "intencion": {
            "type": "string",
            "description": "Intencion detectada por el agente."
          },
          "datos_completos": {
            "type": "boolean"
          },
          "datos": {
            "type": "object",
            "additionalProperties": true
          },
          "respuesta_usuario": {
            "type": "string",
            "description": "Respuesta al usuario cuando faltan datos o es conversacion general."
          },
          "interaccion": {
            "$ref": "#/components/schemas/ServiceInteraction"
          }
        }
      },
      "ServiceInteraction": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "HistoryItem": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "user | assistant | system"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "User": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
