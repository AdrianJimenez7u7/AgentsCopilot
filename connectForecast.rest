# Connect Forecast - Agente conversacional
# Requiere que el servidor este corriendo:
# npm run dev
#
# La extension REST Client puede leer API_KEY desde .env con {{$dotenv API_KEY}}.

@baseUrl = http://localhost:3000
@apiKey = {{$dotenv API_KEY}}

POST {{baseUrl}}/agente/connect-forecast/query
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "question": "¿Cuántas oportunidades de SA se ganaron en Junio de alma?"
}
